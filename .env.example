# copy ไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ environment จริง

# ─── Mango Schema Proxy ────────────────────────────────────────────────────────
# URL ของ Mango API — server ของ MangoBI จะเรียก Mango ผ่านนี้ (browser ไม่เห็น)
NUXT_MANGO_BASE=http://localhost/service/

# ─── Main Service (browser → Mango โดยตรง) ────────────────────────────────────
# ⚠️  ต้องเป็น IP/hostname ที่ browser ของ User เข้าถึงได้
#     localhost ใช้ได้เฉพาะถ้า User เปิด browser บนเครื่องเดียวกับ Mango
NUXT_PUBLIC_API_BASE=http://<mango-server-ip>/service/

# ─── Planning Service (browser → Planning Backend โดยตรง) ─────────────────────
NUXT_PUBLIC_PLANNING_BASE=http://<planning-server-ip>:8310/api/v1/
